# Local-only provider configuration. Copy to .env and fill in one provider.
# Bun loads .env automatically for `bun run ...`; never commit the real .env file.

# Tavily is the default WebSearch provider.
VIBE_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Alternative hosted provider:
# VIBE_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=

# Alternative self-hosted provider:
# VIBE_SEARCH_PROVIDER=searxng
# SEARXNG_URL=http://localhost:8080
